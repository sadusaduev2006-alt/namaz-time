/*
  Cache-Control: max-age=86400
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

*.html
  Cache-Control: max-age=3600, must-revalidate

*.css
  Cache-Control: max-age=31536000, immutable

*.js
  Cache-Control: max-age=31536000, immutable

*.json
  Cache-Control: max-age=31536000, immutable

*.png
  Cache-Control: max-age=31536000, immutable

*.jpg
  Cache-Control: max-age=31536000, immutable

*.svg
  Cache-Control: max-age=31536000, immutable
